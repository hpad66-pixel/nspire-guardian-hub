# ─────────────────────────────────────────────────────────────
# Supabase — standalone project (migrated off Lovable Cloud)
# Copy this file to .env.local and fill in real values.
# In GitHub, these same names must exist as repo secrets for CI + Deploy.
# ─────────────────────────────────────────────────────────────

# Frontend (baked into Vite build — public)
VITE_SUPABASE_URL=https://xlfwzqpixlrnntzqhvcm.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<anon-public-key>
VITE_SUPABASE_PROJECT_ID=xlfwzqpixlrnntzqhvcm

# Supabase CLI (deploy pipeline only — never commit real values)
# Needed by .github/workflows/deploy.yml for `supabase link` + `supabase db push`.
SUPABASE_ACCESS_TOKEN=<personal-access-token-from-supabase.com/dashboard/account/tokens>
SUPABASE_DB_PASSWORD=<database-password-for-project>

# Optional — set only if edge functions or seed scripts need admin access
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# E2E tests (Playwright)
E2E_BASE_URL=http://localhost:5173
