# ─────────────────────────────────────────────────────────────
# Edge Function runtime secrets
# Set these in: Supabase Dashboard → Project Settings → Edge Functions → Secrets
# (NOT GitHub secrets — these are read at runtime by Deno.env.get inside functions)
#
# To push all at once from CLI (after filling in values in a copy of this file):
#   cp supabase/.env.functions.example supabase/.env.functions
#   supabase secrets set --env-file supabase/.env.functions --project-ref xlfwzqpixlrnntzqhvcm
#
# NEVER commit the filled version. It's gitignored (see .gitignore).
# ─────────────────────────────────────────────────────────────

# ── Core ────────────────────────────────────────────────────
# APP_ORIGIN is used by: stripe-webhook, create-checkout, stripe-billing-portal,
#                         saml-acs, accept-portal-invitation
# Example: https://app.yourdomain.com  (or http://localhost:5173 for local dev)
APP_ORIGIN=https://your-app-domain.com

# ── AI / LLM providers ──────────────────────────────────────
# Used by: ai-transcribe, polish-text, generate-proposal,
#          generate-progress-report, extract-transcript-issues
GEMINI_API_KEY=

# Used by: polish-text (fallback when Gemini unavailable)
ANTHROPIC_API_KEY=

# ── Email (Resend) ──────────────────────────────────────────
# Used by: send-email, send-invitation, send-report-email, voice-agent-webhook, run-report
RESEND_API_KEY=

# ── Voice agent (ElevenLabs) ────────────────────────────────
# Used by: voice-agent-token, elevenlabs-transcribe
ELEVENLABS_API_KEY=
ELEVENLABS_AGENT_ID=

# ── Web Push (VAPID) ────────────────────────────────────────
# Used by: send-push-notification
# Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── LearnWorlds webhook ─────────────────────────────────────
# Used by: learnworlds-webhook (HMAC verification of incoming webhooks)
LEARNWORLDS_WEBHOOK_SECRET=

# ── Lovable AI gateway (⚠ LEGACY) ───────────────────────────
# Still referenced by: regulatory-case-review, elevenlabs-transcribe (fallback)
# You're migrating off Lovable, so either:
#   (a) set this to keep the gateway calls working in the interim, OR
#   (b) refactor those two functions to call Gemini/Anthropic directly and drop this key
LOVABLE_API_KEY=

# ── Stripe (A6 · Billing) ───────────────────────────────────
# Used by: stripe-webhook, create-checkout, stripe-billing-portal
STRIPE_SECRET_KEY=sk_test_or_sk_live_xxx
# From Stripe Dashboard → Developers → Webhooks → your endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ── NOT NEEDED (auto-injected by Supabase runtime) ──────────
# SUPABASE_URL              — populated automatically
# SUPABASE_ANON_KEY         — populated automatically
# SUPABASE_SERVICE_ROLE_KEY — populated automatically
# Do NOT set these manually; doing so will override the platform values.
